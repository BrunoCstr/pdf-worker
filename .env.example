NODE_ENV=production

# Redis (BullMQ) — mesma URL do app principal e do Vercel.
# Upstash: copie "Redis URL" no painel (rediss://default:***@xxxx.upstash.io:6379).
# Não use host interno do Coolify (ex.: i4dbn9x19j0...) fora do servidor.
REDIS_URL=
BULLMQ_QUEUE_NAME=drive-pdf-optimize
BULLMQ_DLQ_NAME=drive-pdf-failed
WORKER_CONCURRENCY=1

# Supabase (mesmas credenciais server-side do app principal)
SUPABASE_URL=
# Chave server-side do projeto (SUPABASE_SECRET_KEY no tropa-do-soi). Nao usar a publishable.
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=user-files

# Limits (mirror the main app)
DRIVE_PDF_COMPRESS_MAX_BYTES=524288000
DRIVE_MIN_COMPRESSION_REDUCTION=0.05
DRIVE_PDF_OPTIMIZER_TIMEOUT_MS=300000
DRIVE_DOWNLOAD_TIMEOUT_MS=120000

GHOSTSCRIPT_BINARY=gs

# Optional job signature. HMAC-SHA256 of fileId|userId|storagePath|enqueuedAt.
WORKER_API_SECRET=
