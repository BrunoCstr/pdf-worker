NODE_ENV=production

# Redis (BullMQ) — mesma URL do app principal e do Vercel.
# Upstash: copie "Redis URL" no painel (rediss://default:***@xxxx.upstash.io:6379).
# Não use host interno do Coolify (ex.: i4dbn9x19j0...) fora do servidor.
REDIS_URL=
BULLMQ_QUEUE_NAME=drive-pdf-optimize
BULLMQ_DLQ_NAME=drive-pdf-failed
WORKER_CONCURRENCY=1

# Supabase (mesmas credenciais server-side do app principal)
SUPABASE_URL=
# Chave server-side do projeto (SUPABASE_SECRET_KEY no tropa-do-soi). Nao usar a publishable.
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=user-files

# Limits (mirror the main app)
DRIVE_PDF_COMPRESS_MAX_BYTES=524288000
DRIVE_MIN_COMPRESSION_REDUCTION=0.05
DRIVE_PDF_OPTIMIZER_TIMEOUT_MS=300000
# Extra wall-clock per MB (ceil) on top of base timeout, capped by MAX (large PDFs).
DRIVE_PDF_OPTIMIZER_TIMEOUT_PER_MB_MS=45000
DRIVE_PDF_OPTIMIZER_TIMEOUT_MAX_MS=900000
DRIVE_DOWNLOAD_TIMEOUT_MS=120000

GHOSTSCRIPT_BINARY=gs
# Dedup repeated images (logos/headers em todas as páginas). Pequeno custo de CPU,
# mas reduz bastante o tamanho final em PDFs gerados a partir de templates.
GHOSTSCRIPT_DETECT_DUPLICATE_IMAGES=true
# GHOSTSCRIPT_NUM_RENDERING_THREADS=2

# --- Perfil "study" (material de estudo: tela + impressão ocasional) ---
# Resolução em DPI das imagens (colorida, cinza, monocromática).
# 150 = só tela; 200 = sweet spot tela/impressão; 300 = impressão profissional.
GHOSTSCRIPT_COLOR_IMAGE_RESOLUTION=200
GHOSTSCRIPT_GRAY_IMAGE_RESOLUTION=200
# Mono geralmente é texto digitalizado — mantenha alto para legibilidade.
GHOSTSCRIPT_MONO_IMAGE_RESOLUTION=300
# Qualidade JPEG (1-100). 85 = ebook, 90 = preserva detalhes finos (histologia, MRI), 95+ = quase original.
GHOSTSCRIPT_JPEG_QUALITY=90
# Algoritmo de downsample: Bicubic (melhor qualidade, mais lento),
# Average (rápido, qualidade boa), Subsample (mais rápido, qualidade pior).
GHOSTSCRIPT_COLOR_DOWNSAMPLE_TYPE=Bicubic
GHOSTSCRIPT_GRAY_DOWNSAMPLE_TYPE=Bicubic
GHOSTSCRIPT_MONO_DOWNSAMPLE_TYPE=Subsample
# Auto filter: GS escolhe JPEG (fotos) ou Flate/lossless (diagramas) por imagem.
# CRÍTICO para conteúdo de estudo — sem isso, diagramas viram JPEG e perdem nitidez.
GHOSTSCRIPT_AUTO_FILTER_COLOR_IMAGES=true
GHOSTSCRIPT_AUTO_FILTER_GRAY_IMAGES=true
# Estratégia de conversão de cor. "LeaveColorUnchanged" preserva ECG colorido,
# heatmaps de MRI, coloração de tecidos, etc. Outras opções: RGB | CMYK | Gray.
GHOSTSCRIPT_COLOR_CONVERSION_STRATEGY=LeaveColorUnchanged
# Mantém anotações/highlights que alunos fizeram no PDF.
GHOSTSCRIPT_PRESERVE_ANNOTS=true

# Optional job signature. HMAC-SHA256 of fileId|userId|storagePath|enqueuedAt.
WORKER_API_SECRET=
