{
  "name": "pdf-worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ worker for optimizing Drive PDFs with Ghostscript and Supabase.",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "healthcheck": "node --env-file=.env dist/healthcheck.js"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
